# .gitignore for OpenClaw Workspace

# Secrets and API keys
.secrets
*.secrets
secrets/

# Next.js build cache
mission-control/.next/

# Node modules
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Environment files
.env
.env.local
.env.*.local

# Backup files
*.bak
*.swp
*.tmp
# Keep config backups
!config/*.backup

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/
.next/
mission-control/.env.local
mission-control/.env
agent-bus/agentbus.db
agent-bus/agentbus.db-shm
agent-bus/agentbus.db-wal
